# Beacon reads the ambient AWS credential chain — no secrets belong in this file.
# Copy to .env, fill in what you use, and export before running anything:
#   export $(grep -v '^#' .env | xargs)

AWS_PROFILE=your-profile
AWS_REGION=us-west-2

# --- Injected automatically by `agentcore deploy` (CDK wires these into the
# --- Runtime container's env for you — set them here only for local `agentcore dev`
# --- against already-deployed BeaconMemory/BeaconGateway resources).
MEMORY_BEACONMEMORY_ID=
GATEWAY_BEACONGATEWAY_URL=
GATEWAY_BEACONGATEWAY_AUTH_TYPE=NONE

# --- bin/ scripts (mock order DB + Lambda — not managed by `agentcore add`)
BEACON_ORDERS_TABLE=beacon-orders

# --- ui/app.py (Streamlit chat UI)
BEACON_RUNTIME_ARN=
BEACON_DEV_PORT=8080
